# Open Health Exchange - Environment Variables Example
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED - Django Core
# =============================================================================

# SECURITY: Generate a unique secret key for production
# For development, you can use: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-unique-secret-key-here

# Set to True only for local development
DEBUG=False

# =============================================================================
# REQUIRED - Database
# =============================================================================
DATABASE_URL=postgres://postgres:postgres@localhost:5432/open_health_exchange_local

# =============================================================================
# REQUIRED - Redis (for caching and task queue)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# REQUIRED - OAuth2 Provider Credentials
# =============================================================================

# Withings API credentials (from https://developer.withings.com/)
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=

# Fitbit API credentials (from https://dev.fitbit.com/)
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_SUBSCRIBER_ID=1
FITBIT_VERIFICATION_CODE=

# =============================================================================
# REQUIRED - OIDC/Resource Server Configuration
# =============================================================================
RS_URL=https://your-auth-server.example.com
OIDC_RP_CLIENT_ID=your-client-id
OIDC_RP_CLIENT_SECRET=your-client-secret

# =============================================================================
# REQUIRED - FHIR Server Configuration
# =============================================================================
FHIR_BASE_URL=https://your-fhir-server.example.com/fhir/
FHIR_AUTH_TOKEN_HEADER=Authorization
FHIR_AUTH_TOKEN_VALUE=Bearer your-fhir-token

# =============================================================================
# REQUIRED - Webhook Configuration
# =============================================================================
WEBHOOK_BASE_URL=https://your-domain.example.com/webhooks/

# =============================================================================
# OPTIONAL - Development Settings
# =============================================================================

# Allow OAuth2 without HTTPS in development (NEVER use in production!)
# OAUTHLIB_INSECURE_TRANSPORT=1

# Fix macOS fork issues with multiprocessing/Huey workers
# OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES

# Allowed hosts (comma-separated for multiple, or * for development)
# ALLOWED_HOST=*

# =============================================================================
# OPTIONAL - Production Settings
# =============================================================================

# ENVIRONMENT=production
# APPLICATION_VERSION=1.0.0
